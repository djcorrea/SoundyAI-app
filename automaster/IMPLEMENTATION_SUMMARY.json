  "guarantees": [
    "Zero risco de degradação sonora (rescue usa APENAS gain)",
    "Bloqueio conservador (preferimos bloquear a processar arriscado)",
    "Transparência total (JSON estruturado com todas as decisões)",
    "Determínistico (mesmo input → mesmo output)",
    "Produção-ready (testado com arquivos reais)"
  ],
  "integration_guide": {
    "backend_workflow": [
      "1. Usuário faz upload do WAV",
      "2. Backend executa: node measure-audio.cjs <file.wav>",
      "3. Backend executa: node check-aptitude.cjs <lufs> <tp> <target_lufs>",
      "4a. Se APTA: executar pipeline normalmente",
      "4b. Se NÃO_APTA: exibir modal ao usuário",
      "5. Usuário pode escolher: 'Reenviar arquivo' OU 'Tentar Rescue Mode'",
      "6. Se Rescue Mode: executar pipeline com --rescue",
      "7a. Se RESCUED + masterização OK: entregar arquivo",
      "7b. Se ABORT_UNSAFE_INPUT: exibir erro e pedir reupload"
    ],
    "api_endpoints_suggested": [
      "POST /api/v1/audio/measure (retorna LUFS + TP)",
      "POST /api/v1/audio/check-aptitude (retorna isApt + reasons)",
      "POST /api/v1/audio/rescue (executa rescue mode)",
      "POST /api/v1/audio/master (pipeline completo, aceita flag rescueMode)"
    ]
  },
