{
  "implementation": {
    "name": "Gate de Aptidão + Rescue Mode",
    "version": "1.0.0",
    "date": "2026-02-12",
    "status": "PRODUCTION_READY"
  },
  "components": {
    "measure_audio": {
      "file": "automaster/measure-audio.cjs",
      "purpose": "Medir LUFS-I e True Peak via FFmpeg loudnorm",
      "usage": "node measure-audio.cjs <input.wav>",
      "output": "JSON com lufs_i e true_peak_db"
    },
    "check_aptitude": {
      "file": "automaster/check-aptitude.cjs",
      "purpose": "Determinar se áudio está APTO para masterização",
      "usage": "node check-aptitude.cjs <lufs_i> <true_peak_db> <target_lufs>",
      "output": "JSON com isApt, reasons, recommended_actions"
    },
    "rescue_mode": {
      "file": "automaster/rescue-mode.cjs",
      "purpose": "Criar headroom via gain-only (APENAS volume)",
      "usage": "node rescue-mode.cjs <input.wav> <output_tmp.wav>",
      "output": "JSON com status (RESCUED | ABORT_UNSAFE_INPUT | ALREADY_SAFE)"
    },
    "master_pipeline": {
      "file": "automaster/master-pipeline.cjs",
      "purpose": "Pipeline completo com gate + rescue integrado",
      "usage": "node master-pipeline.cjs <input.wav> <output.wav> <MODE> [--rescue]",
      "output": "JSON com ok, status, aptitude_check, rescue_result, final_decision"
    }
  },
  "thresholds": {
    "true_peak_max": -1.0,
    "true_peak_max_unit": "dBTP",
    "lufs_margin_above_target": 3.0,
    "lufs_margin_unit": "LU",
    "rescue_desired_tp": -1.2,
    "rescue_desired_tp_unit": "dBTP",
    "rescue_safe_limit": -1.0,
    "rescue_safe_limit_unit": "dBTP"
  },
  "modes": {
